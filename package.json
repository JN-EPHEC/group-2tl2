    "@types/supertest": "^7.2.0",
    "concurrently": "^8.2.2",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
